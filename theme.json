{
	"version": 3,
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	],
	"settings": {
		"appearanceTools": true,
		"custom": {
			"lineHeight": {
				"normal": "1.5",
				"tight": "1.05",
				"snug": "1.15",
				"h6": "1.15",
				"h5": "1.15",
				"h4": "1.15",
				"h3": "1.15",
				"h2": "1.08",
				"h1": "1.05"
			},
			"radius": {
				"md": "8px"
			},
			"container": "1440px",
			"gutter": "72px",
			"contentWidth": "720px"
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1440px"
		},
		"spacing": {
			"customSpacingSize": false,
			"spacingSizes": [
				{
					"slug": "0",
					"size": "0",
					"name": "0"
				},
				{
					"slug": "xs",
					"size": "12px",
					"name": "Extra Small"
				},
				{
					"slug": "sm",
					"size": "24px",
					"name": "Small"
				},
				{
					"slug": "md",
					"size": "40px",
					"name": "Medium"
				},
				{
					"slug": "lg",
					"size": "56px",
					"name": "Large"
				},
				{
					"slug": "xl",
					"size": "72px",
					"name": "Extra Large"
				},
				{
					"slug": "section",
					"size": "100px",
					"name": "Section"
				}
			],
			"units": [ "px", "em", "rem", "%", "vw", "vh" ],
			"padding": true,
			"margin": true,
			"blockGap": true
		},
		"color": {
			"custom": false,
			"palette": [
				{
					"slug": "orange",
					"color": "#FFA500",
					"name": "Orange"
				},
				{
					"slug": "orange-dark",
					"color": "#E69500",
					"name": "Orange Dark"
				},
				{
					"slug": "orange-deep",
					"color": "#CC8400",
					"name": "Orange Deep"
				},
				{
					"slug": "kahel-50",
					"color": "#FFF8EB",
					"name": "Kahel 50"
				},
				{
					"slug": "kahel-100",
					"color": "#FFEFD5",
					"name": "Kahel 100"
				},
				{
					"slug": "kahel-200",
					"color": "#FFE0A8",
					"name": "Kahel 200"
				},
				{
					"slug": "kahel-600",
					"color": "#FFB733",
					"name": "Kahel 600"
				},
				{
					"slug": "white",
					"color": "#FFFFFF",
					"name": "White"
				},
				{
					"slug": "stone-50",
					"color": "#FAFAF9",
					"name": "Stone 50"
				},
				{
					"slug": "stone-100",
					"color": "#F5F5F4",
					"name": "Stone 100"
				},
				{
					"slug": "stone-200",
					"color": "#E7E5E4",
					"name": "Stone 200"
				},
				{
					"slug": "stone-400",
					"color": "#A8A29E",
					"name": "Stone 400"
				},
				{
					"slug": "stone-600",
					"color": "#57534E",
					"name": "Stone 600"
				},
				{
					"slug": "stone-900",
					"color": "#1C1917",
					"name": "Stone 900"
				},
				{
					"slug": "background",
					"color": "#FFFFFF",
					"name": "Background"
				},
				{
					"slug": "background-secondary",
					"color": "#FAFAF9",
					"name": "Background Secondary"
				},
				{
					"slug": "background-accent",
					"color": "#FFF8EB",
					"name": "Background Accent"
				},
				{
					"slug": "background-inverse",
					"color": "#1C1917",
					"name": "Background Inverse"
				},
				{
					"slug": "text",
					"color": "#1C1917",
					"name": "Text"
				},
				{
					"slug": "text-secondary",
					"color": "#44403C",
					"name": "Text Secondary"
				},
				{
					"slug": "text-muted",
					"color": "#57534E",
					"name": "Text Muted"
				},
				{
					"slug": "text-inverse",
					"color": "#FFFFFF",
					"name": "Text Inverse"
				},
				{
					"slug": "brand",
					"color": "#E69500",
					"name": "Brand"
				},
				{
					"slug": "border-light",
					"color": "#E7E5E4",
					"name": "Border Light"
				},
				{
					"slug": "border-default",
					"color": "#D6D3D1",
					"name": "Border Default"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "\"Fraunces\"",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [ "file:./assets/fonts/fraunces-700.woff2" ]
						},
						{
							"fontFamily": "\"Fraunces\"",
							"fontStyle": "normal",
							"fontWeight": "800",
							"src": [ "file:./assets/fonts/fraunces-800.woff2" ]
						},
						{
							"fontFamily": "\"Fraunces\"",
							"fontStyle": "italic",
							"fontWeight": "700",
							"src": [ "file:./assets/fonts/fraunces-700italic.woff2" ]
						}
					],
					"fontFamily": "\"Fraunces\", Georgia, serif",
					"name": "Fraunces",
					"slug": "fraunces"
				},
				{
					"fontFace": [
						{
							"fontFamily": "\"Source Sans 3\"",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [ "file:./assets/fonts/source-sans-3-400.woff2" ]
						},
						{
							"fontFamily": "\"Source Sans 3\"",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [ "file:./assets/fonts/source-sans-3-600.woff2" ]
						},
						{
							"fontFamily": "\"Source Sans 3\"",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [ "file:./assets/fonts/source-sans-3-700.woff2" ]
						}
					],
					"fontFamily": "\"Source Sans 3\", system-ui, -apple-system, sans-serif",
					"name": "Source Sans 3",
					"slug": "source-sans-3"
				}
			],
			"fontSizes": [
				{
					"slug": "xs",
					"size": "11px",
					"name": "Extra Small"
				},
				{
					"slug": "small",
					"size": "14px",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "16px",
					"name": "Body"
				},
				{
					"slug": "large",
					"size": "18px",
					"name": "Large"
				},
				{
					"slug": "h6",
					"size": "18px",
					"name": "Heading 6"
				},
				{
					"slug": "h5",
					"size": "21px",
					"name": "Heading 5"
				},
				{
					"slug": "h4",
					"size": "24px",
					"name": "Heading 4"
				},
				{
					"slug": "h3",
					"size": "31px",
					"name": "Heading 3"
				},
				{
					"slug": "h2",
					"size": "clamp(32px, 4vw, 48px)",
					"name": "Heading 2"
				},
				{
					"slug": "h1",
					"size": "clamp(44px, 4vw, 60px)",
					"name": "Heading 1"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--text)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--source-sans-3)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "var(--wp--custom--line-height--normal)"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--h-1)",
					"lineHeight": "var(--wp--custom--line-height--h-1)",
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontWeight": "800"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--h-2)",
					"lineHeight": "var(--wp--custom--line-height--h-2)",
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontWeight": "800"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--h-3)",
					"lineHeight": "var(--wp--custom--line-height--h-3)",
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontWeight": "700"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--h-4)",
					"lineHeight": "var(--wp--custom--line-height--h-4)",
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontWeight": "700"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--h-5)",
					"lineHeight": "var(--wp--custom--line-height--h-5)",
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontWeight": "700"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--h-6)",
					"lineHeight": "var(--wp--custom--line-height--h-6)",
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontWeight": "700"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--brand)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--orange-deep)"
					}
				}
			},
			"button": {
				"border": {
					"radius": "var(--wp--custom--radius--md)"
				},
				"color": {
					"background": "var(--wp--preset--color--orange)",
					"text": "var(--wp--preset--color--text)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--orange-dark)",
						"text": "var(--wp--preset--color--text)"
					}
				}
			}
		},
		"blocks": {
			"core/button": {
				"border": {
					"radius": "8px"
				},
				"typography": {
					"fontSize": "14px",
					"fontWeight": "600"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "14px",
					"fontWeight": "600"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontSize": "24px",
					"fontWeight": "800"
				}
			},
			"core/post-author": {
				"typography": {
					"fontSize": "15px"
				}
			},
			"core/post-date": {
				"typography": {
					"fontSize": "12px",
					"fontWeight": "600"
				}
			}
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--md)",
			"padding": {
				"top": "0",
				"bottom": "0"
			}
		}
	}
}
